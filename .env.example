# Supabase project configuration
# Copy this file to .env.local and fill in your own values.
# These variables are exposed to the client bundle (Vite requires the VITE_ prefix).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================
# RegData (regdata.apis.bg) — за scripts/load-eik.py
# Само за локални/server-side скриптове, НЕ за клиента.
# ============================================
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
REGDATA_USERNAME=
REGDATA_PASSWORD=
REGDATA_PACKET_ID=1

