# ============================================================
# Frontend (Vite) — публично достъпни променливи в bundle-а
# ============================================================
#
# Live (production) build:
#   VITE_SUPABASE_URL и VITE_SUPABASE_ANON_KEY идват от GitHub Secrets
#   при deploy от main branch. НЯМА нужда от локален .env за production.
#
# Локална разработка / dev среда:
#   Копирай този файл в .env.local и попълни стойностите от твоя dev
#   Supabase проект (виж DEV-SETUP.md).
#
# Visual marker:
#   VITE_DEV_ENV — ако е сетнат на "dev" / "test", потребителят вижда
#   видима жълта лента горе: „⚠️ DEV СРЕДА — промените НЕ са на live".
#   На production остави празно или махни реда.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_DEV_ENV=dev

# ============================================================
# RegData (regdata.apis.bg) — за scripts/load-eik.py
# Само за локални / server-side скриптове, НЕ за клиента.
# ============================================================
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
REGDATA_USERNAME=
REGDATA_PASSWORD=
REGDATA_PACKET_ID=1
